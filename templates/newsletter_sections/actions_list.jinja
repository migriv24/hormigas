<tr>
  <td style="background:#ffffff;border-radius:16px;padding:18px 20px;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);font-family:Arial,Helvetica,sans-serif;">
    <div style="font-size:16px;font-weight:700;">
      {{ title | default("Actions for the network") }}
    </div>
    <ol style="margin:10px 0 0 18px;font-size:14px;line-height:1.6;color:#374151;">
      {% for item in items %}
      <li{% if not loop.last %} style="margin-bottom:4px;"{% endif %}>{{ item }}</li>
      {% endfor %}
    </ol>
  </td>
</tr>
