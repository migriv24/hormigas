<tr>
  <td style="background:#ffffff;border-radius:16px;padding:18px 20px;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);font-family:Arial,Helvetica,sans-serif;">

    {% if title %}
    <div style="font-size:16px;font-weight:700;color:#111827;">
      {{ title }}
    </div>
    {% endif %}

    {% if subtitle %}
    <div style="font-size:13px;line-height:1.6;color:#374151;margin-top:6px;">{{ subtitle }}</div>
    {% endif %}

    {% if show_graphic and graphic_url %}
    <div style="margin-top:14px;">
      <img src="{{ graphic_url }}" alt="{{ title | default('Document Preview') }}"
           style="width:100%;border-radius:12px;display:block;
                  border:1px solid #e5e7eb;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
    </div>
    {% endif %}

    <div style="margin-top:14px;padding:12px 16px;background:#f3f4f6;border-radius:10px;
                display:inline-flex;align-items:center;gap:10px;width:100%;box-sizing:border-box;">
      <span style="font-size:22px;line-height:1;">📎</span>
      <span style="font-size:13px;color:#374151;line-height:1.5;">
        {{ caption | default("Full PDF attached below") }}
      </span>
    </div>

  </td>
</tr>
