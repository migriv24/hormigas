<tr>
  <td style="background:#ffffff;border-radius:16px;padding:18px 20px;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
      <tbody><tr>
        <td style="font-family:Arial,Helvetica,sans-serif;color:#111827;">
          <div style="font-size:16px;font-weight:700;line-height:1.3;">
            People who attended {{ meeting_date }}
          </div>
          {% if note %}
          <div style="font-size:12px;line-height:1.5;color:#6b7280;margin-top:6px;">{{ note }}</div>
          {% endif %}

          {% set half = (attendees | length // 2) %}
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
                 style="margin-top:12px;">
            <tbody><tr>
              <td style="width:50%;vertical-align:top;padding-right:10px;">
                <ul style="margin:0;padding-left:18px;font-size:14px;line-height:1.8;color:#374151;">
                  {% for person in attendees[:half] %}
                  <li>{{ person.name }}{% if person.org %} ({{ person.org }}){% endif %}</li>
                  {% endfor %}
                </ul>
              </td>
              <td style="width:50%;vertical-align:top;padding-left:10px;">
                <ul style="margin:0;padding-left:18px;font-size:14px;line-height:1.8;color:#374151;">
                  {% for person in attendees[half:] %}
                  <li>{{ person.name }}{% if person.org %} ({{ person.org }}){% endif %}</li>
                  {% endfor %}
                </ul>
              </td>
            </tr></tbody>
          </table>

          {% if footer_note %}
          <div style="margin-top:12px;font-size:13px;line-height:1.6;color:#374151;">
            {{ footer_note }}
          </div>
          {% endif %}
        </td>
      </tr></tbody>
    </table>
  </td>
</tr>
