<tr>
  <td style="background:#ffffff;border-radius:16px;padding:18px 20px;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);font-family:Arial,Helvetica,sans-serif;">

    <div style="font-size:16px;font-weight:700;">
      {{ title | default("Flyers & Community Resources") }}
    </div>
    {% if subtitle %}
    <div style="font-size:13px;line-height:1.6;color:#374151;margin-top:6px;">{{ subtitle }}</div>
    {% endif %}

    {% if layout == "grid" %}
    <!-- 2-column grid -->
    <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:14px;">
      <tbody>
        {% set ns = namespace(col=0) %}
        {% for img in images %}
          {% if ns.col == 0 %}<tr>{% endif %}
          <td width="50%" valign="top" style="padding:6px;">
            <img src="{{ img.url }}" alt="{{ img.alt | default('') }}"
                 style="width:100%;border-radius:12px;display:block;">
          </td>
          {% set ns.col = ns.col + 1 %}
          {% if ns.col == 2 %}
            </tr>
            {% set ns.col = 0 %}
          {% endif %}
        {% endfor %}
        {% if ns.col == 1 %}
          <td width="50%" valign="top" style="padding:6px;"></td></tr>
        {% endif %}
      </tbody>
    </table>
    {% else %}
    <!-- Single column stack -->
    {% for img in images %}
    <img src="{{ img.url }}" alt="{{ img.alt | default('') }}"
         style="width:100%;margin-top:12px;border-radius:12px;display:block;">
    {% endfor %}
    {% endif %}

  </td>
</tr>
