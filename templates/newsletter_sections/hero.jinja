<tr>
  <td style="background:#ffffff;border-radius:16px;overflow:hidden;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
      <tbody>
        {% if image_url %}
        <tr>
          <td>
            <img src="{{ image_url }}" width="680" alt="Hero image"
                 style="display:block;width:100%;height:auto;border:0;margin:0;padding:0;">
          </td>
        </tr>
        {% endif %}
        <tr>
          <td style="padding:18px 20px 6px 20px;font-family:Arial,Helvetica,sans-serif;color:#111827;">
            <div style="font-size:18px;font-weight:700;line-height:1.3;">{{ title }}</div>
            {% for para in body_paragraphs %}
            <div style="font-size:14px;line-height:1.6;color:#374151;margin-top:{% if loop.first %}8{% else %}10{% endif %}px;">
              {{ para }}
            </div>
            {% endfor %}
          </td>
        </tr>
        <tr>
          <td style="padding:10px 20px 20px 20px;font-family:Arial,Helvetica,sans-serif;
                     font-size:12px;color:#6b7280;">
            Group email: <strong>{{ group_email }}</strong>
          </td>
        </tr>
      </tbody>
    </table>
  </td>
</tr>
