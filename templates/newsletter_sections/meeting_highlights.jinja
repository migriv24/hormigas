<tr>
  <td style="background:#ffffff;border-radius:16px;padding:18px 20px;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);">
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
      <tbody>
        <tr>
          <td style="font-family:Arial,Helvetica,sans-serif;color:#111827;">
            <div style="font-size:16px;font-weight:700;line-height:1.3;">
              {{ title | default("Meeting highlights") }}
            </div>
            <ul style="margin:10px 0 0 18px;padding:0;font-size:14px;line-height:1.6;color:#374151;">
              {% for item in items %}
              <li style="margin-bottom:{% if not loop.last %}8{% else %}0{% endif %}px;">{{ item }}</li>
              {% endfor %}
            </ul>
          </td>
        </tr>
      </tbody>
    </table>
  </td>
</tr>
