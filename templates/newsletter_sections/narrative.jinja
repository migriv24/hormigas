<tr>
  <td style="background:#ffffff;border-radius:16px;padding:18px 20px;
             box-shadow:0 8px 24px rgba(17,24,39,0.08);">

    <!-- Section header with icon -->
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
      <tbody><tr>
        {% if icon_url %}
        <td style="width:56px;vertical-align:top;padding-right:14px;">
          <img src="{{ icon_url }}" width="44" height="44" alt=""
               style="display:block;border-radius:12px;background:#ecfeff;padding:8px;">
        </td>
        {% endif %}
        <td style="font-family:Arial,Helvetica,sans-serif;color:#111827;vertical-align:middle;">
          <div style="font-size:16px;font-weight:700;line-height:1.3;">{{ title }}</div>
        </td>
      </tr></tbody>
    </table>

    <!-- Body text -->
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%"
           style="margin-top:10px;">
      <tbody><tr>
        <td style="font-family:Arial,Helvetica,sans-serif;color:#111827;">

          {% if rich_content %}
          {# Rich content from the WYSIWYG customizer — rendered as-is #}
          <div style="font-size:14px;line-height:1.7;color:#374151;">
            {{ rich_content | safe }}
          </div>

          {% else %}
          {# Simple fields fallback #}
          {% for para in body_paragraphs %}
          <div style="font-size:14px;line-height:1.6;color:#374151;margin-top:{% if loop.first %}0{% else %}10{% endif %}px;">
            {{ para }}
          </div>
          {% endfor %}

          {% if items %}
          <ul style="margin:10px 0 0 18px;padding:0;font-size:14px;line-height:1.6;color:#374151;">
            {% for item in items %}
            <li style="margin-bottom:{% if not loop.last %}8{% else %}0{% endif %}px;">{{ item }}</li>
            {% endfor %}
          </ul>
          {% endif %}

          {% if callout %}
          <div style="margin-top:12px;padding:12px;border-radius:12px;
                      background:{{ callout.bg | default('#f9fafb') }};
                      border:1px solid {{ callout.border | default('#e5e7eb') }};">
            <div style="font-size:13px;font-weight:700;color:{{ callout.title_color | default('#111827') }};
                        font-family:Arial,Helvetica,sans-serif;">
              {{ callout.title }}
            </div>
            <div style="font-size:13px;line-height:1.6;color:{{ callout.body_color | default('#374151') }};
                        margin-top:6px;font-family:Arial,Helvetica,sans-serif;">
              {{ callout.body }}
            </div>
          </div>
          {% endif %}
          {% endif %}

        </td>
      </tr></tbody>
    </table>

  </td>
</tr>
